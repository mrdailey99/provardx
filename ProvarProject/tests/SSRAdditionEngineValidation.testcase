      <clauses>
        <clause name="hidden" testItemId="111">
          <steps>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.testapis.ApexSoqlQuery" name="ApexSoqlQuery" testItemId="116" title="SOQL Query: select Id from IPE_GSKU_SSR_Data__c\nWHERE CreatedByID = '0051Y000009LDBbQAO'\nAND Date__c &gt;= {TODAY}=&gt;IPE_GSKU_SSR_DataRows">
              <arguments>
                <argument id="soqlQuery">
                  <value class="compound">
                    <parts>
                      <value valueClass="string">select Id from IPE_GSKU_SSR_Data__c\nWHERE CreatedByID = '0051Y000009LDBbQAO'\nAND Date__c &gt;= </value>
                      <variable>
                        <path element="TODAY"/>
                      </variable>
