    <apiCall apiId="com.provar.plugins.bundled.apis.control.StepGroup" name="StepGroup" testItemId="101" title="Query Total PUF rows created by test user and delete">
      <arguments>
        <argument id="description">
          <value class="value" valueClass="string">Query Total PUF rows created by test user and delete</value>
        </argument>
      </arguments>
      <clauses>
        <clause name="hidden" testItemId="102">
          <steps>
            <apiCall apiId="com.provar.plugins.forcedotcom.core.testapis.ApexSoqlQuery" name="ApexSoqlQuery" testItemId="83" title="SOQL Query: select Id from IPE_Total_PUF_Data__c\nWHERE CreatedByID = '0051Y000009LDBbQAO'\nAND Date__c &gt;= {TODAY}=&gt;IPE_Total_PUF_DataRows">
              <arguments>
                <argument id="soqlQuery">
                  <value class="compound">
                    <parts>
                      <value valueClass="string">select Id from IPE_Total_PUF_Data__c\nWHERE CreatedByID = '0051Y000009LDBbQAO'\nAND Date__c &gt;= </value>
                      <variable>
                        <path element="TODAY"/>
                      </variable>
                    </parts>
                  </value>
                </argument>
                <argument id="apexConnectionName">
                  <value class="value" valueClass="string">BusinessBOM</value>
                </argument>
                <argument id="resultListName">
                  <value class="value" valueClass="string">IPE_Total_PUF_DataRows</value>
                </argument>
                <argument id="resultScope">
                  <value class="value" valueClass="string">Test</value>
                </argument>
              </arguments>
            </apiCall>
            <apiCall apiId="com.provar.plugins.bundled.apis.control.ForEach" name="ForEach" testItemId="84" title="For Each: {IPE_Total_PUF_DataRows}=&gt;TotalPUFRow">
              <arguments>
                <argument id="list">
                  <value class="variable">
                    <path element="IPE_Total_PUF_DataRows"/>
                  </value>
                </argument>
                <argument id="fromItem">
                  <value class="value" valueClass="decimal">1</value>
                </argument>
                <argument id="valueName">
                  <value class="value" valueClass="string">TotalPUFRow</value>
                </argument>
                <argument id="continueOnFailure"/>
              </arguments>
              <clauses>
                <clause name="substeps" testItemId="85">
                  <steps>
                    <apiCall apiId="com.provar.plugins.forcedotcom.core.testapis.ApexDeleteObject" name="ApexDeleteObject" testItemId="87" title="Delete Object: {TotalPUFRow.Id}">
                      <arguments>
                        <argument id="apexConnectionName">
                          <value class="value" valueClass="string">BusinessBOM</value>
                        </argument>
                        <argument id="objectId">
                          <value class="variable">
                            <path element="TotalPUFRow"/>
                            <path element="Id"/>
                          </value>
                        </argument>
                      </arguments>
                    </apiCall>
                  </steps>
                </clause>
              </clauses>
            </apiCall>
          </steps>
        </clause>
      </clauses>
    </apiCall>
