            <apiCall apiId="com.provar.plugins.forcedotcom.core.ui.UiDoAction" name="UiDoAction" testItemId="9" title="Click the Tile One">
              <arguments>
                <argument id="locator">
                  <value class="uiLocator" uri="ui:pageobject:field?field=tileOne&amp;pageId=pageobjects.ProductExplorer"/>
